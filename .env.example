# Database (local PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://marketpulse:marketpulse@localhost:5432/marketpulse

# Redis (future-ready, not used yet)
REDIS_URL=redis://localhost:6379/0

# Binance (crypto data)
BINANCE_BASE_URL=https://api.binance.com

# CoinGecko (crypto metadata for seed script)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Ingestion
INGESTION_INTERVAL_MINUTES=5
INGESTION_BACKFILL_DAYS=7

# Scheduler (set to true to enable automatic periodic ingestion)
SCHEDULER_ENABLED=false

# Anomaly detection thresholds
ANOMALY_PRICE_ZSCORE_THRESHOLD=2.5
ANOMALY_VOLUME_ZSCORE_THRESHOLD=3.0
ANOMALY_RSI_UPPER=80
ANOMALY_RSI_LOWER=20

# LLM — Multi-provider support
# LLM_PROVIDER selects legacy single-provider mode: local|claude|gemini|groq|mistral|openrouter|ollama
# New AI assistant uses the intelligent router (auto-selects cheapest model per task)
LLM_PROVIDER=local

# Provider API keys (get free keys at each provider's website)
# ANTHROPIC_API_KEY=your-key      # https://console.anthropic.com
# GEMINI_API_KEY=your-key          # https://aistudio.google.com/apikey (FREE)
# GROQ_API_KEY=your-key            # https://console.groq.com (FREE tier)
# MISTRAL_API_KEY=your-key         # https://console.mistral.ai
# OPENROUTER_API_KEY=your-key      # https://openrouter.ai/keys
OLLAMA_BASE_URL=http://localhost:11434
# CEREBRAS_API_KEY=your-key         # https://cloud.cerebras.ai (FREE 1M tokens/day)
# SAMBANOVA_API_KEY=your-key        # https://cloud.sambanova.ai (FREE forever)

# LLM_MODEL=claude-sonnet-4-20250514
LLM_COST_TRACKING=true
LLM_MONTHLY_BUDGET_USD=20.0

# News aggregation (all have free tiers)
# FINNHUB_API_KEY=your-key          # https://finnhub.io (FREE, 60 req/min — best!)
# MARKETAUX_API_KEY=your-key        # https://www.marketaux.com (FREE, 80+ markets)
# ALPHAVANTAGE_API_KEY=your-key     # https://www.alphavantage.co (FREE, 25 req/day)

# App
APP_ENV=development
LOG_LEVEL=INFO
