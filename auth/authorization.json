{
  "level": "auto_approve",
  "deploy_allowed": false,
  "allowed_actions": [
    "read_file",
    "write_file",
    "git_commit",
    "run_tests",
    "lint_check"
  ],
  "forbidden_actions": [
    "deploy",
    "access_secrets",
    "call_broker_api",
    "push_to_production",
    "modify_infra"
  ],
  "allowed_paths_prefixes": [
    "src/",
    "tests/"
  ],
  "forbidden_paths": [
    ".env",
    "infra/",
    "secrets/"
  ],
  "max_files_changed": 3,
  "max_change_loc": 300,
  "max_iterations": 5,
  "audit_required": true
}
